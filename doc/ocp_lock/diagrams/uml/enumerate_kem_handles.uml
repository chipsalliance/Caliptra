'
' OCP Lock: ENUMERATE_KEM_HANDLES API sequence diagram showing Caliptra FW/HW interactions
'
'
@startuml

!include utils.inc

note across
    <b>Preconditions:</b>
        * Caliptra FW manages which keys are in which slots in KV
end note

fw -> mb++ : ENUMERATE_KEM_HANDLES

mb -> cfw++ : Message
mb--

cfw -> cfw: Create list of valid KEM handles
note right cfw
    One handle for each KEM algorithm supported
end note

cfw -> mb : Command response\nkem_handles
& mb -> fw++ : Command\ncomplete
cfw--

@enduml
